{
  "name": "mailgui233",
  "version": "0.1.2",
  "description": "Small cross-platform desktop mail GUI built with Tauri, TypeScript, React, and Vite.",
  "author": "neko233-com",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "build:renderer": "vite build",
    "build:fast": "npm run build:renderer",
    "build": "npm run typecheck && npm run build:fast",
    "test:e2e": "playwright test",
    "verify:visual": "npm run build && npm run test:e2e",
    "package:smoke": "tauri build --no-bundle --ci --config ./src-tauri/tauri.no-build.conf.json",
    "ci:tauri-smoke": "npm run build:renderer && npm run package:smoke",
    "package": "tauri build",
    "dist": "tauri build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
