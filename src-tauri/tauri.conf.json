{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MailGUI233",
  "version": "0.1.2",
  "identifier": "com.neko233.mailgui233",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:renderer",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MailGUI233",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "neko233-com",
    "category": "Productivity",
    "shortDescription": "Small multi-provider desktop mail GUI",
    "longDescription": "A small cross-platform desktop mail GUI with multi-provider mail views, channel validation, and mail timetable layouts."
  }
}
